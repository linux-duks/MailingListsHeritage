diff -r 6251a9fdf8f9 drivers/md/md.c
--- a/drivers/md/md.c	Mon Aug 25 14:22:06 2008 +1000
+++ b/drivers/md/md.c	Mon Aug 25 14:27:32 2008 +1000
@@ -44,14 +44,9 @@
